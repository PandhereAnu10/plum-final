# Copy this file to ".env" and fill in real values. Do not commit ".env".
#
# Dev server (recommended — uses backend/.venv and avoids reload on .venv):
#   cd backend
#   .\run_dev.ps1
#
# If you see: ModuleNotFoundError: No module named 'websockets.asyncio'
# use the venv Python above, or: pip install "websockets>=13" inside .venv

# Supabase (server inserts: prefer SERVICE_ROLE if RLS blocks anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (optional; for SQL clients / migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Groq (Llama 3.1 70B — adjudication)
GROQ_API_KEY=your-groq-api-key

# Policy row must exist in DB (from policy_terms.json)
DEFAULT_POLICY_CODE=PLUM_OPD_2024

# Optional: Tesseract if not at default Windows path
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
